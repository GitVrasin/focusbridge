<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme — Compose handles colors; this is just the base for the window -->
    <style name="Theme.FocusBridge" parent="android:Theme.Material.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Intervention window: no animations, appears immediately over other apps -->
    <style name="Theme.FocusBridge.Intervention" parent="Theme.FocusBridge">
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowShowWallpaper">false</item>
    </style>
</resources>

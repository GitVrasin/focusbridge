<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Usage stats: user must grant manually in Settings → Special app access → Usage access -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Notifications (runtime permission on Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Restart service on boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Request to be excluded from Doze battery optimization -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Exact alarms for AlarmManager heartbeat (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Partial wake lock to keep CPU alive during monitoring tick -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".FocusBridgeApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FocusBridge"
        tools:targetApi="35">

        <!-- Main entry point -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.FocusBridge">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Intervention full-screen overlay Activity.
            showWhenLocked + turnScreenOn let it appear over the lock screen.
            excludeFromRecents keeps it off the recents list.
            Separate taskAffinity so it doesn't merge with the main back-stack.
        -->
        <activity
            android:name=".ui.intervention.InterventionActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:taskAffinity="com.focusbridge.intervention"
            android:theme="@style/Theme.FocusBridge.Intervention" />

        <!-- Background usage monitoring service -->
        <service
            android:name=".service.UsageMonitorService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Restart service after device reboot -->
        <receiver
            android:name=".service.BootCompletedReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- AlarmManager heartbeat receiver: wakes the service if it was killed by the OS -->
        <receiver
            android:name=".service.HeartbeatReceiver"
            android:exported="false" />

    </application>
</manifest>
